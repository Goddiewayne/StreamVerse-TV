<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon background: brand "deep space" radial gradient, full-bleed so any launcher
     mask (circle, squircle, rounded square) is filled edge to edge. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="48"
                android:gradientRadius="76">
                <item android:offset="0" android:color="#1E2A45"/>
                <item android:offset="0.6" android:color="#0F172A"/>
                <item android:offset="1" android:color="#080C14"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
