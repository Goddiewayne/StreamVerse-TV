    <path
        android:fillColor="#0D22D3EE"
        android:pathData="M21,57 L163,57 L163,121 L21,121 Z" />

    <!-- Play triangle (CyberCyan, centered in screen) -->
    <path
        android:fillColor="#22D3EE"
        android:pathData="M72,74 L72,104 L104,89 Z" />

    <!-- Violet glow dot at play tip -->
    <path
        android:fillColor="#818CF8"
        android:pathData="M104,89m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0" />

