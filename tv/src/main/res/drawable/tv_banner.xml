    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Background — deep space -->
    <path
        android:fillColor="#080C14"
        android:pathData="M0,0 L320,0 L320,180 L0,180 Z" />

    <!-- Subtle grid lines (cinematic scanline effect, very low opacity) -->
    <path android:strokeColor="#0822D3EE" android:strokeWidth="1"
        android:pathData="M0,45 L320,45 M0,90 L320,90 M0,135 L320,135" />
    <path android:strokeColor="#0822D3EE" android:strokeWidth="1"
        android:pathData="M80,0 L80,180 M160,0 L160,180 M240,0 L240,180" />

    <!-- Cyan vertical accent bar (left edge — mirrors mobile's category header accent) -->
    <path
        android:fillColor="#22D3EE"
        android:pathData="M0,50 L4,50 L4,130 L0,130 Z" />

    <!-- Violet secondary accent bar (thinner, offset) -->
    <path
        android:fillColor="#818CF8"
        android:pathData="M6,65 L8,65 L8,115 L6,115 Z" />

    <!-- TV screen body -->
    <path
        android:fillColor="#1E293B"
        android:pathData="M24,54 L160,54 Q166,54 166,60 L166,118 Q166,124 160,124 L112,124 L112,132 L122,132 L122,136 L62,136 L62,132 L72,132 L72,124 L24,124 Q18,124 18,118 L18,60 Q18,54 24,54 Z" />

