<?xml version="1.0" encoding="utf-8"?>
<!-- TV leanback banner (320×180 dp) — shown on the Android TV home launcher.
     Brand identity: deep-space background, cyan TV silhouette, violet accent, signal arcs. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
